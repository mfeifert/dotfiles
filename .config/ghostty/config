bold-color = bright
cursor-style-blink = false
font-family = monospace
font-feature = -calt,-dlig,-liga
font-size = 12
fullscreen = false
gtk-titlebar = false
mouse-hide-while-typing = true
shell-integration-features = no-cursor
theme = dark:maf-midnight-in-mojave,light:maf-Raycast_Light
# theme = noctalia
unfocused-split-opacity = 1
window-decoration = none

window-width = 160
window-height = 64

keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right
